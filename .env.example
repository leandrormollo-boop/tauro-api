# ============================================================
# Variables de entorno para Tauro API
# ============================================================
# En Render, copiar estas keys al panel "Environment" del servicio.
# El archivo credenciales.json se sube como "Secret File" en /etc/secrets/.

# ── App ─────────────────────────────────────────────────────
ENV=PROD                              # PROD = oculta el link mágico en pantalla
BASE_URL=https://app.taurosolutions.ar
SESSION_COOKIE_SECURE=1               # 1 = cookies solo por HTTPS
GOOGLE_CREDENTIALS_FILE=/etc/secrets/credenciales.json

# ── Google Sheets (sheet del API) ───────────────────────────
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/.../edit

# ── Email SMTP (Gmail App Password) ─────────────────────────
EMAIL_REMITENTE=tu-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_DESTINO=tu-email@gmail.com

# ── FedEx ───────────────────────────────────────────────────
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENVIRONMENT=sandbox             # sandbox | production

# ── Job semanal de actualización de precios ─────────────────
MARGEN_MINIMO_ALERTA_ARS=5000
CRON_DIA=mon
CRON_HORA=6
